# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Twilio Configuration
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=

TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER="+19082578393"
TWILIO_MESSAGING_SERVICE_SID=
# Required

# Messaging Service (RECOMMENDED - provides better deliverability and RCS support)
# Create a Messaging Service at: https://console.twilio.com/us1/develop/sms/services
# Add your phone number(s) to the service
# Format: MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Leave blank if using phone number directly


# Phone Number (FALLBACK - only needed if not using Messaging Service)
# Your Twilio phone number in E.164 format
# Format: +1234567890
# Only required if TWILIO_MESSAGING_SERVICE_SID is not set
# TWILIO_PHONE_NUMBER=+1234567890

# Optional OpenAI Configuration
# The RCS approval demo uses predefined flows and does not require OpenAI.
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional Configuration

# Maximum image size in megabytes (default: 20)
MAX_IMAGE_SIZE_MB=20

# Demo state and public support info
DATA_DIR=data
BRAND_NAME=WorkOnward
SUPPORT_EMAIL=support@workonward.com
APP_BASE_URL=https://twilio-rcs-production.up.railway.app
PUBLIC_BASE_URL=https://workonward.com
MESSAGING_TERMS_URL=https://www.workonward.com/en/terms
MESSAGING_PRIVACY_URL=https://www.workonward.com/en/privacy
# Public app host that serves generated RCS media from /assets/rcs.
# For Railway production, set this to the Railway app URL.
RCS_ASSET_BASE_URL=https://twilio-rcs-production.up.railway.app

# RCS Sender profile
# Use #3D3D3D as the Twilio Console sender accent color.
# The app serves generated WorkOnward RCS media from:
#   ${PUBLIC_BASE_URL}/assets/rcs
#   ${PUBLIC_BASE_URL}/assets/rcs/workonward-logo.png
#   ${PUBLIC_BASE_URL}/assets/rcs/workonward-banner.png

# Disable Twilio webhook signature validation (USE ONLY FOR DEVELOPMENT)
# IMPORTANT: Set to false or remove this line in production for security
# Default: false (validation enabled)
DISABLE_SIGNATURE_VALIDATION=false

NGROK_AUTH_TOKEN=

GEMINI_API_KEY=

RCS_CONTENT_CONSENT_SID=
RCS_CONTENT_LANGUAGE_SID=
RCS_CONTENT_ROLE_SID=
RCS_CONTENT_LOCATION_SID=
RCS_CONTENT_SHIFT_SID=
RCS_CONTENT_JOBS_CAROUSEL_SID=
RCS_CONTENT_ACTIONS_SID=
RCS_CONTENT_APPLY_FOLLOWUP_SID=
RCS_CONTENT_APPLY_CLOSING_SID=
RCS_CONTENT_HELP_SID=
RCS_CONTENT_HANDOFF_SID=
